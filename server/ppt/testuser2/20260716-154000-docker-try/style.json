{
  "name": "blue-white-professional",
  "display_name": "简洁专业 · 蓝白",
  "description": "简洁专业的蓝白配色风格，适合技术分享场景",
  "colors": {
    "primary": "#1a73e8",
    "primary_dark": "#0d47a1",
    "primary_light": "#e8f0fe",
    "secondary": "#34a853",
    "accent": "#ea4335",
    "neutral_dark": "#202124",
    "neutral_mid": "#5f6368",
    "neutral_light": "#dadce0",
    "background": "#ffffff",
    "background_alt": "#f8f9fa",
    "text_primary": "#202124",
    "text_secondary": "#5f6368",
    "text_on_primary": "#ffffff",
    "border": "#e0e0e0",
    "success": "#34a853",
    "warning": "#fbbc04",
    "white": "#ffffff"
  },
  "typography": {
    "font_family": "'Inter', 'Segoe UI', -apple-system, sans-serif",
    "font_family_mono": "'JetBrains Mono', 'Fira Code', 'Consolas', monospace",
    "font_size_base": "16px",
    "line_height_base": 1.6,
    "headings": {
      "h1": { "size": "2.5rem", "weight": 700, "letter_spacing": "-0.025em" },
      "h2": { "size": "1.75rem", "weight": 600, "letter_spacing": "-0.02em" },
      "h3": { "size": "1.25rem", "weight": 600 },
      "h4": { "size": "1rem", "weight": 600 }
    },
    "body": { "size": "1rem", "weight": 400 },
    "caption": { "size": "0.875rem", "weight": 400, "color": "#5f6368" },
    "code": { "size": "0.875rem", "weight": 400 }
  },
  "spacing": {
    "section_padding": "3rem",
    "card_padding": "1.5rem",
    "card_gap": "1.25rem",
    "content_gap": "1rem"
  },
  "border_radius": {
    "card": "12px",
    "button": "8px",
    "code_block": "8px"
  },
  "shadows": {
    "card": "0 2px 8px rgba(0,0,0,0.08)",
    "card_hover": "0 4px 16px rgba(0,0,0,0.12)",
    "elevated": "0 8px 24px rgba(0,0,0,0.12)"
  },
  "layout": {
    "cover": { "template": "center-hero", "background": "linear-gradient(135deg, #0d47a1 0%, #1a73e8 100%)" },
    "end": { "template": "center-cta", "background": "linear-gradient(135deg, #0d47a1 0%, #1a73e8 100%)" },
    "section": { "template": "symmetric", "background": "#ffffff" }
  },
  "components": {
    "card": {
      "background": "#ffffff",
      "border": "1px solid #e0e0e0",
      "border_radius": "12px",
      "padding": "1.5rem",
      "box_shadow": "0 2px 8px rgba(0,0,0,0.08)"
    },
    "code_block": {
      "background": "#1e1e1e",
      "text_color": "#d4d4d4",
      "border_radius": "8px",
      "padding": "1rem 1.25rem"
    },
    "button_primary": {
      "background": "#1a73e8",
      "text_color": "#ffffff",
      "border_radius": "8px",
      "padding": "0.75rem 1.5rem"
    }
  },
  "animations": {
    "page_transition": "fade 0.3s ease",
    "card_enter": "slideUp 0.4s ease"
  },
  "decoration_budget": "low",
  "image_policy": "minimal_icons_only"
}
